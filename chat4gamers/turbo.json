{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": ["DISABLE_EXTRACTION", "NODE_ENV", "EAS_BUILD_PLATFORM"],
  "pipeline": {
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "build": {
      "env": ["DISABLE_EXTRACTION", "NODE_ENV", "EAS_BUILD_PLATFORM"],
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "out/**",
        "dist/**",
        "index.js",
        "!.next/cache/**",
        "build/**",
        "node_modules/.cache/metro/**",
        "*.node"
      ]
    },
    "package": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
