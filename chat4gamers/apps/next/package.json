{
  "name": "next-app",
  "version": "1.0.6",
  "description": "Voice Chat App for Gamers",
  "author": "M-Byte480 @ GitHub",
  "private": true,
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "cd ../.. && yarn build && cd apps/next && next build",
    "start": "next start",
    "serve": "NODE_ENV=production next start --port 8151",
    "lint": "biome check .",
    "test": "vitest",
    "electron": "cross-env NODE_ENV=development electron .",
    "package": "yarn build && npx electron-builder build --win --publish always",
    "package:debug": "yarn build && npx electron-builder build --win --dir",
    "package:installer": "yarn build && npx electron-builder build --win"
  },
  "build": {
    "appId": "com.yourname.geechat",
    "productName": "GeeChat",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.ts",
      "out/**/*",
      "package.json",
      "tsconfig.json",
      "index.js"
    ],
    "win": {
      "target": "nsis",
      "publish": {
        "provider": "generic",
        "url": "https://REDACTED_DOMAIN/updates/"
      }
    },
    "asar": true
  },
  "dependencies": {
    "@tamagui/config": "^2.0.0-rc.0",
    "@tamagui/next-theme": "^2.0.0-rc.0",
    "app": "0.0.0",
    "electron-updater": "^6.8.3",
    "next": "16.1.1",
    "raf": "^3.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-web": "^0.21.2",
    "tamagui": "^2.0.0-rc.0",
    "vercel": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tamagui/next-plugin": "^2.0.0-rc.0",
    "@types/node": "^20.14.1",
    "cross-env": "^10.1.0",
    "electron": "40.4.1",
    "electron-builder": "26.7.0",
    "next-compose-plugins": "^2.2.1",
    "next-transpile-modules": "^10.0.1",
    "tree-kill": "^1.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  }
}
