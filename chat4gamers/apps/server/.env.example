# ── LiveKit credentials ───────────────────────────────────────────────────────
# Run setup.sh to generate these automatically, or fill them in manually.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Database encryption ───────────────────────────────────────────────────────
# Leave blank to disable SQLite encryption (not recommended for production).
DB_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# The public IP or hostname of this server. Used by LiveKit for WebRTC routing.
SERVER_IP=

NODE_ENV=production
