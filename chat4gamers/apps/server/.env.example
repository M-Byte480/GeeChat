# ── LiveKit credentials ───────────────────────────────────────────────────────
# Run setup.sh to generate these automatically, or fill them in manually.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# WebSocket URL clients connect to directly. Defaults to ws://localhost:7880.
# In dev: ws://localhost:7880  |  In prod: ws://<SERVER_IP>:7880
LIVEKIT_URL=

# ── Database encryption ───────────────────────────────────────────────────────
# Leave blank to disable SQLite encryption (not recommended for production).
DB_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# The public IP or hostname of this server. Used by LiveKit for WebRTC routing.
SERVER_IP=

NODE_ENV=production

# ── GIF support (optional) ────────────────────────────────────────────────────
# Get a key at https://klipy.co — leave blank to disable the GIF picker.
KLIPY_API_KEY=
