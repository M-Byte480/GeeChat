{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeeChat",
  "version": "0.1.0",
  "identifier": "m-byte.geechat",
  "build": {
    "frontendDist": "../../next/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "yarn workspace next-app dev",
    "beforeBuildCommand": "yarn workspace next-app build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GeeChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "visible": false,
        "decorations": false,
        "shadow": true,
        "resizable": true
      },
      {
        "label": "splash",
        "title": "GeeChat",
        "url": "splash.html",
        "width": 420,
        "height": 260,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
